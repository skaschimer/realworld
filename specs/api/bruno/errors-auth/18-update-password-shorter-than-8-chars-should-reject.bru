meta {
  name: Update password shorter than 8 chars - should reject
  type: http
  seq: 18
}

put {
  url: {{host}}/api/user
  body: json
  auth: none
}

headers {
  Authorization: Token {{token}}
}

body:json {
  {
    "user": {
      "password": "short7c"
    }
  }
}

assert {
  res.status: eq 422
}
